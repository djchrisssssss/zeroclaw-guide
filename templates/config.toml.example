# Copy this file to ~/.zeroclaw/config.toml with:
#   install -m 600 templates/config.toml.example ~/.zeroclaw/config.toml
#
# Keep this file outside the git repo after copying.
# Do NOT place blockchain private keys or mnemonic phrases on this host.

# =========================
# ZeroClaw main settings
# =========================
default_provider = "openrouter"

# Prefer runtime.env for API keys instead of placing them here.
# api_key = "<YOUR_API_KEY>"

# Optional model override
# model = "openrouter/auto"

# Bind locally unless you intentionally expose webhook mode.
# gateway_host = "127.0.0.1"
# gateway_port = 42617

# =========================
# Telegram channel settings
# =========================
[channels_config.telegram]
bot_token = "<YOUR_TELEGRAM_BOT_TOKEN>"
allowed_users = ["<YOUR_TELEGRAM_USER_ID>"]
stream_mode = "partial"
draft_update_interval_ms = 1000
mention_only = false
interrupt_on_new_message = false
